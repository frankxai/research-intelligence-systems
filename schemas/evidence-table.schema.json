{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Table Schema",
  "description": "A systematic evidence table record aggregating study-level data for a research question, supporting meta-analysis, narrative synthesis, and GRADE certainty assessment.",
  "type": "object",
  "required": ["table_id", "research_question", "domain", "created_at"],
  "properties": {
    "table_id": {
      "type": "string",
      "description": "Unique identifier for this evidence table"
    },
    "research_question": {
      "type": "string",
      "description": "The structured research question this table addresses (PICO/PECO format preferred)"
    },
    "domain": {
      "type": "string",
      "enum": ["neuroscience", "psychology", "cognitive-science", "learning-science", "behavioral-science", "consciousness-studies", "interdisciplinary"]
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "table_name": {
      "type": "string",
      "description": "Human-readable name for this evidence table"
    },
    "review_type": {
      "type": "string",
      "enum": ["systematic-review", "meta-analysis", "scoping-review", "rapid-review", "narrative-review", "umbrella-review", "living-review"],
      "description": "Type of evidence synthesis"
    },
    "prisma_compliant": {
      "type": "boolean",
      "description": "Whether the review follows PRISMA reporting guidelines"
    },
    "protocol_registered": {
      "type": "boolean",
      "description": "Whether a review protocol was preregistered (PROSPERO, OSF, etc.)"
    },
    "protocol_url": {
      "type": "string",
      "format": "uri"
    },
    "search_databases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Databases searched (e.g. PubMed, PsycINFO, ERIC, Cochrane, Scopus, Web of Science)"
    },
    "search_date_range": {
      "type": "object",
      "properties": {
        "from": { "type": "string", "format": "date" },
        "to": { "type": "string", "format": "date" }
      }
    },
    "inclusion_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit inclusion criteria applied during screening"
    },
    "exclusion_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "total_screened": {
      "type": "integer",
      "minimum": 0,
      "description": "Total records screened at title/abstract stage (for PRISMA)"
    },
    "total_full_text_assessed": {
      "type": "integer",
      "minimum": 0
    },
    "total_included": {
      "type": "integer",
      "minimum": 0,
      "description": "Total studies included in the synthesis"
    },
    "entries": {
      "type": "array",
      "description": "One entry per included study",
      "items": {
        "type": "object",
        "required": ["doi"],
        "properties": {
          "doi": { "type": "string", "pattern": "^10\\..+" },
          "authors": { "type": "string", "description": "Author string (e.g. 'Smith et al., 2022')" },
          "year": { "type": "integer" },
          "study_design": { "type": "string" },
          "N": { "type": "integer", "minimum": 0 },
          "intervention_or_exposure": { "type": "string" },
          "comparator": { "type": "string" },
          "outcome_measure": { "type": "string" },
          "outcome_domain": { "type": "string" },
          "effect_size": { "type": "number" },
          "effect_size_type": { "type": "string" },
          "ci_lower": { "type": "number" },
          "ci_upper": { "type": "number" },
          "p_value": { "type": "number", "minimum": 0, "maximum": 1 },
          "follow_up_weeks": { "type": "number", "description": "Follow-up duration in weeks (0 = immediate post)" },
          "risk_of_bias": {
            "type": "string",
            "enum": ["low", "some-concerns", "high", "not-assessed"]
          },
          "rob_tool": {
            "type": "string",
            "enum": ["Cochrane-RoB2", "ROBINS-I", "Newcastle-Ottawa", "QUADAS-2", "JBI", "other"]
          },
          "preregistered": { "type": "boolean" },
          "open_data": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "pooled_effect_size": {
      "type": "number",
      "description": "Meta-analytic pooled effect size"
    },
    "pooled_effect_size_type": { "type": "string" },
    "pooled_ci_lower": { "type": "number" },
    "pooled_ci_upper": { "type": "number" },
    "heterogeneity_i2": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "I² heterogeneity statistic (%)"
    },
    "heterogeneity_tau2": {
      "type": "number",
      "description": "Between-study variance τ²"
    },
    "heterogeneity_q_p": {
      "type": "number",
      "description": "p-value for Cochran's Q test of heterogeneity"
    },
    "publication_bias_assessment": {
      "type": "string",
      "enum": ["no-evidence", "suspected", "confirmed", "not-assessed"],
      "description": "Publication bias evaluation (Egger's test, funnel plot, PET-PEESE)"
    },
    "grade_certainty": {
      "type": "string",
      "enum": ["high", "moderate", "low", "very-low"],
      "description": "GRADE overall certainty of evidence"
    },
    "grade_domains": {
      "type": "object",
      "description": "GRADE domain ratings",
      "properties": {
        "risk_of_bias": { "type": "string", "enum": ["not-serious", "serious", "very-serious"] },
        "inconsistency": { "type": "string", "enum": ["not-serious", "serious", "very-serious"] },
        "indirectness": { "type": "string", "enum": ["not-serious", "serious", "very-serious"] },
        "imprecision": { "type": "string", "enum": ["not-serious", "serious", "very-serious"] },
        "publication_bias": { "type": "string", "enum": ["undetected", "strongly-suspected"] }
      }
    },
    "conclusion": {
      "type": "string",
      "description": "Narrative conclusion summarizing the evidence"
    },
    "created_by": { "type": "string" },
    "reviewed_by": { "type": "string" }
  },
  "additionalProperties": false
}
